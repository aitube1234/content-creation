APP_NAME=content_creation
APP_ENV=development
APP_PORT=8000

# Database
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/content_creation
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# AWS
AWS_REGION=us-east-1
AWS_SECRET_NAME=content_creation/secrets

# Video Generation Pipeline
PIPELINE_BASE_URL=http://localhost:8001
PIPELINE_TIMEOUT=30
PIPELINE_MAX_RETRIES=3
PIPELINE_BACKOFF_FACTOR=2.0

# JWT Authentication
JWT_ALGORITHM=HS256
JWT_AUDIENCE=content_creation
JWT_SECRET_NAME=content_creation/jwt-secret
JWT_SECRET_KEY=dev-secret-key-change-in-production

# Content Validation
MIN_CONTENT_LENGTH=10
MAX_CONTENT_LENGTH=50000

# Logging
LOG_LEVEL=INFO
SERVICE_NAME=content_creation
